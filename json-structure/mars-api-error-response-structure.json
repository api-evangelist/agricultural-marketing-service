{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/agricultural-marketing-service/refs/heads/main/json-structure/mars-api-error-response-structure.json",
  "name": "Error Response",
  "description": "Standard error response from the MARS API.",
  "type": "object",
  "properties": {
    "error": {
      "type": "string",
      "description": "Error type or code.",
      "example": "invalid_parameter"
    },
    "message": {
      "type": "string",
      "description": "Human-readable error message.",
      "example": "The requested resource was not found."
    },
    "status": {
      "type": "int32",
      "description": "HTTP status code.",
      "example": 404
    }
  }
}